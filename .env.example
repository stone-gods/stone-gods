# Database (Neon pooled URL for app + Vercel)
DATABASE_URL=

# Auth.js (Discord login)
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Daily spin allowance
DAILY_SPIN_LIMIT=1
SPIN_COOLDOWN_HOURS=24

# NFT win odds
# WIN_POOL_SIZE: max one global NFT win per this many completed spins (default 100)
WIN_POOL_SIZE=100
# NFT_WIN_THRESHOLD: per-spin win chance when pool allows (threshold / 10000, default 100 = 1%)
NFT_WIN_THRESHOLD=100

# Dev flags
DEV_UNLIMITED_SPINS=false
DEV_FORCE_WIN=false
ALLOWED_DEV_ORIGINS=

# Solana NFT prize claim
SOLANA_RPC_URL=
PRIZE_WALLET=
PRIZE_WALLET_PRIVATE_KEY=
# Set true to skip on-chain transfer during testing
MOCK_NFT_CLAIM=true
