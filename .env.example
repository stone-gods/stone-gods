# Database (Neon pooled URL for app + Vercel)
DATABASE_URL=

# Auth.js (Discord login)
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Stone Gods Discord — required in production so only server members can spin
# Bot must be in the guild with Create Instant Invite permission
DISCORD_GUILD_ID=
DISCORD_BOT_TOKEN=
# Optional fallback link shown if auto-join fails
DISCORD_INVITE_URL=

# Daily spin allowance
DAILY_SPIN_LIMIT=1
SPIN_COOLDOWN_HOURS=12

# NFT win odds
# WIN_POOL_SIZE: max one global NFT win per this many completed spins (default 100)
WIN_POOL_SIZE=100
# NFT_WIN_THRESHOLD: 1-in-N chance per spin when pool allows (default 100 = 1%)
NFT_WIN_THRESHOLD=100

# Dev flags (ignored on Vercel/production unless ALLOW_DEV_FLAGS_IN_PRODUCTION=true)
DEV_UNLIMITED_SPINS=false
DEV_FORCE_WIN=false
ALLOW_DEV_FLAGS_IN_PRODUCTION=false
ALLOWED_DEV_ORIGINS=

# Solana NFT prize claim
SOLANA_RPC_URL=
# Optional — if omitted, the public address is derived from PRIZE_WALLET_PRIVATE_KEY
PRIZE_WALLET=
# Base58 secret key, or JSON byte array from solana-keygen: [1,2,3,...]
PRIZE_WALLET_PRIVATE_KEY=
# Set true to skip on-chain transfer during local testing (ignored in production)
MOCK_NFT_CLAIM=true

# Git push (per-project PAT — avoids wrong cached GitHub credentials)
# Classic PAT: repo scope. Fine-grained: Contents Read and write on stone-gods/stone-gods
GITHUB_PAT=
